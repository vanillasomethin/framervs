{
  "name": "vanillasometh-in",
  "version": "1.0.0",
  "private": true,
  "description": "Vanilla & Somethin' — React (Next.js) site rendering Framer components via unframer.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "framer:export": "unframer $FRAMER_PROJECT_ID --outDir ./src/framer",
    "framer:watch": "unframer $FRAMER_PROJECT_ID --outDir ./src/framer --watch"
  },
  "dependencies": {
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "unframer": "^4.1.9"
  }
}
